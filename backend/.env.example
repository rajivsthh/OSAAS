PORT=3001
NODE_ENV=development

# CORS Configuration (comma-separated list of allowed origins)
# For production, add your deployed frontend URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Firebase Admin SDK (for production deployment)
# Get these from Firebase Console > Project Settings > Service Accounts > Generate new private key
# For local development, you can use serviceAccountKey.json instead
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# Optional: Add Claude API key for AI-powered report summaries
# Get your key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Note: AI summaries will still work without the API key,
# but will use a basic summary generator instead of Claude
